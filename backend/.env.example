APP_ENV=development
DATABASE_URL=sqlite:///./change_radar.db
# CloudBase 生产环境请设置以下五项；配置后优先于 DATABASE_URL。
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECT_MAX_ATTEMPTS=12
DB_CONNECT_RETRY_SECONDS=5
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
AUTO_CREATE_TABLES=false
SEED_DEMO_DATA=true
INTERNAL_USER_KEY=internal-demo
WECHAT_APPID=
REQUIRE_WECHAT_IDENTITY=false
MARKET_DATA_PROVIDER=sina
MARKET_SYNC_INTERVAL_SECONDS=15
MARKET_CANDIDATE_LIMIT_PER_BOARD=20
MARKET_HTTP_TIMEOUT_SECONDS=12
MARKET_HTTP_USE_ENVIRONMENT_PROXY=false
